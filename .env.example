# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/ggec
MONGODB_DB_NAME=ggec

# App
APP_URL=http://localhost:3000

# Seeded admin account (created on first login if missing)
SEED_STAFF_EMAIL=your-admin@example.com
SEED_STAFF_PASSWORD=your-secure-admin-password

# Default password for new player profiles (admin can override when creating)
DEFAULT_USER_PASSWORD=welcome1
NEXT_PUBLIC_DEFAULT_USER_PASSWORD=welcome1

# SMTP (Nodemailer) — welcome emails and session invoice emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM="GGEZZ Gaming Cafe <noreply@example.com>"
